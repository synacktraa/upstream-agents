# Database (Neon PostgreSQL via Vercel)
DATABASE_URL="postgres://user:password@host/database?sslmode=require"
DATABASE_URL_UNPOOLED="postgres://user:password@host/database?sslmode=require"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# GitHub OAuth App
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Encryption key for Anthropic credentials (stored encrypted in DB)
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# Daytona API (shared for all users, server-side only)
DAYTONA_API_KEY="dtn_your_api_key"

# Smithery MCP Registry API (shared for all users, server-side only)
SMITHERY_API_KEY="your-smithery-api-key"

# OpenRouter API (free fallback for AI-powered naming when users don't have their own API keys)
# Uses the free model: arcee-ai/trinity-mini:free
OPENROUTER_API_KEY="your-openrouter-api-key"

# Optional: use local coding-agents-sdk from /Users/jamie/codeagentsdk (for dev only; run USE_LOCAL_SDK=1 npm install first)
# USE_LOCAL_SDK=1

# GitHub Personal Access Token for local development (NEVER use in production!)
# When set, authentication is bypassed and a dev user is auto-created.
# The PAT is used for all GitHub operations (cloning, fetching repos, etc.)
# Required scopes: repo, read:user
# GITHUB_PAT=ghp_xxxxxxxxxxxx

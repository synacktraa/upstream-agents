{
  "name": "sandboxed-agents-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @sandboxed-agents/web",
    "build": "npm run build -w @sandboxed-agents/sdk && npm run build -w @sandboxed-agents/web",
    "build:sdk": "npm run build -w @sandboxed-agents/sdk",
    "build:web": "npm run build -w @sandboxed-agents/web",
    "start": "npm run start -w @sandboxed-agents/web",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

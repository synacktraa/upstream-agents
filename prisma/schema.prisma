generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String?          @unique
  emailVerified DateTime?
  image         String?
  githubId      String?          @unique
  githubLogin   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  repoOrder     Json?
  isAdmin       Boolean          @default(false)
  maxSandboxes  Int?
  accounts      Account[]
  repos         Repo[]
  sandboxes     Sandbox[]
  sessions      Session[]
  credentials   UserCredentials?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserCredentials {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  anthropicApiKey          String?
  anthropicAuthType        String   @default("api-key")
  anthropicAuthToken       String?
  updatedAt                DateTime @updatedAt
  sandboxAutoStopInterval  Int      @default(5)
  openaiApiKey             String?
  daytonaApiKey            String?
  opencodeApiKey           String?
  defaultLoopMaxIterations Int      @default(10)
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Repo {
  id            String          @id @default(cuid())
  userId        String
  name          String
  owner         String
  avatar        String?
  defaultBranch String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  envVars       Json?
  branches      Branch[]
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  mcpServers    RepoMcpServer[]

  @@unique([userId, owner, name])
}

model RepoMcpServer {
  id           String    @id @default(cuid())
  repoId       String
  slug         String
  name         String
  url          String
  iconUrl      String?
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?
  status       String    @default("pending")
  lastError    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  clientId     String?
  repo         Repo      @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([repoId, slug])
  @@index([repoId])
}

model Branch {
  id     String @id @default(cuid())
  repoId String
  repo   Repo   @relation(fields: [repoId], references: [id], onDelete: Cascade)

  name        String
  baseBranch  String?
  startCommit String?
  status      String  @default("idle") // "idle" | "running" | "creating" | "stopped" | "error"
  prUrl       String?
  draftPrompt String? @db.Text // Persisted draft input for chat continuity

  // Agent configuration
  agent String @default("claude-code") // "claude-code" | "opencode" | "codex"
  model String? // Model selection for the agent (e.g., "sonnet", "gpt-4o")

  // Loop mode configuration
  loopEnabled       Boolean @default(false) // Is loop mode active for this branch?
  loopCount         Int     @default(0)     // Current number of loop iterations
  loopMaxIterations Int     @default(10)    // Max iterations before stopping

  // Commit tracking - HEAD at start of last execution, used for detecting new commits
  lastShownCommitHash String?

  sandbox  Sandbox?
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([repoId, name])
}

model Sandbox {
  id                String   @id @default(cuid())
  sandboxId         String   @unique
  sandboxName       String
  userId            String
  branchId          String   @unique
  contextId         String?
  sessionId         String?
  previewUrlPattern String?
  status            String   @default("creating")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastActiveAt      DateTime @default(now())
  sessionAgent      String?
  branch            Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id            String          @id @default(cuid())
  branchId      String
  role          String
  content       String
  toolCalls     Json?
  timestamp     String?
  commitHash    String?
  commitMessage String?
  createdAt     DateTime        @default(now())
  contentBlocks Json?
  agentId       String?
  execution     AgentExecution?
  branch        Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId, createdAt])
}

model AgentExecution {
  id                   String    @id @default(cuid())
  messageId            String    @unique
  sandboxId            String
  executionId          String?   @unique
  status               String    @default("running")
  startedAt            DateTime  @default(now())
  completedAt          DateTime?
  latestSnapshot       Json?
  accumulatedEvents    Json?
  lastSnapshotPolledAt DateTime?
  isLoopIteration      Boolean   @default(false)
  message              Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([sandboxId, status])
}

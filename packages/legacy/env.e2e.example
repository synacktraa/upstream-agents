# Copy to `.env.e2e` (gitignored) and fill in. Playwright loads it via playwright.config.ts.
#
# DATABASE_URL=
# DATABASE_URL_UNPOOLED=
# NEXTAUTH_SECRET=
# ENCRYPTION_KEY=
#
# Optional: Claude Max OAuth (same JSON as Settings → Claude subscription field).
# Use a single line or dotenv-supported quoting so the full JSON is one value.
# E2E_CLAUDE_OAUTH_JSON={"claudeAiOauth":{"accessToken":"...","refreshToken":"...","expiresAt":0,"scopes":[],"subscriptionType":"max","rateLimitTier":"..."}}

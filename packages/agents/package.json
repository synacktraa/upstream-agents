{
  "name": "background-agents",
  "version": "0.1.2",
  "description": "A TypeScript SDK for interacting with various AI coding agents (Claude, Codex, OpenCode, Gemini, Pi)",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc && npm run build:eliza-bundle && npm run build:eliza-embed",
    "build:eliza-bundle": "esbuild src/agents/eliza/cli.ts --bundle --platform=node --format=esm --outfile=dist/agents/eliza/cli.bundle.js",
    "build:eliza-embed": "npx tsx scripts/embed-eliza-bundle.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "generate:jsonl-refs": "npx tsx scripts/generate-jsonl-references.ts"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "claude",
    "codex",
    "opencode",
    "gemini",
    "pi",
    "sdk"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "next.config.codeagentsdk.cjs"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*",
    "./next.config": "./next.config.codeagentsdk.cjs"
  },
  "dependencies": {
    "@daytonaio/sdk": "^0.150.0",
    "dotenv": "^17.3.1"
  }
}

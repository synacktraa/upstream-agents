generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String?          @unique
  emailVerified DateTime?
  image         String?
  githubId      String?          @unique
  githubLogin   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  repoOrder     Json?
  isAdmin       Boolean          @default(false)
  maxSandboxes  Int?
  accounts      Account[]
  repos         Repo[]
  sandboxes     Sandbox[]
  sessions      Session[]
  credentials   UserCredentials?
  activityLogs  ActivityLog[]
  ownedTeam     Team?            @relation("TeamOwner")
  teamMembership TeamMember?
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserCredentials {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  anthropicApiKey           String?
  anthropicAuthType         String   @default("api-key")
  anthropicAuthToken        String?
  updatedAt                 DateTime @updatedAt
  sandboxAutoStopInterval   Int      @default(5)
  openaiApiKey              String?
  daytonaApiKey             String?
  opencodeApiKey            String?
  geminiApiKey              String?
  squashOnMerge             Boolean  @default(false)
  prDescriptionMode         String   @default("ai") // "ai" or "commits"
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Team {
  id        String       @id @default(cuid())
  ownerId   String       @unique
  owner     User         @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members   TeamMember[]
  createdAt DateTime     @default(now())
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String   @unique
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Repo {
  id            String          @id @default(cuid())
  userId        String
  name          String
  owner         String
  avatar        String?
  defaultBranch      String
  preferredBaseBranch String?
  createdAt          DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  envVars       Json?
  branches      Branch[]
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  mcpServers    RepoMcpServer[]

  @@unique([userId, owner, name])
}

model RepoMcpServer {
  id           String    @id @default(cuid())
  repoId       String
  slug         String
  name         String
  url          String
  iconUrl      String?
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?
  status       String    @default("pending")
  lastError    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  clientId     String?
  repo         Repo      @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([repoId, slug])
  @@index([repoId])
}

model Branch {
  id     String @id @default(cuid())
  repoId String
  repo   Repo   @relation(fields: [repoId], references: [id], onDelete: Cascade)

  name        String
  baseBranch  String?
  startCommit String?
  status      String  @default("idle") // "idle" | "running" | "creating" | "stopped" | "error"
  prUrl       String?
  draftPrompt String? @db.Text // Persisted draft input for chat continuity

  // Agent configuration
  agent String @default("claude-code") // "claude-code" | "opencode" | "codex"
  model String? // Model selection for the agent (e.g., "sonnet", "gpt-4o")

  // Commit tracking - HEAD at start of last execution, used for detecting new commits
  lastShownCommitHash String?

  // Sync flag - set when remote is updated (e.g., merge into this branch) and sandbox needs to pull
  needsSync Boolean @default(false)

  sandbox  Sandbox?
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([repoId, name])
}

model Sandbox {
  id                String   @id @default(cuid())
  sandboxId         String   @unique
  sandboxName       String
  userId            String
  branchId          String   @unique
  contextId         String?
  sessionId         String?
  previewUrlPattern String?
  status            String   @default("creating")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastActiveAt      DateTime @default(now())
  sessionAgent      String?
  branch            Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id            String          @id @default(cuid())
  branchId      String
  role          String
  content       String
  toolCalls     Json?
  timestamp     String?
  commitHash    String?
  commitMessage String?
  createdAt     DateTime        @default(now())
  contentBlocks Json?
  /// Ephemeral push-retry UI payload (same shape as PushErrorInfo); survives reload when set
  pushError     Json?
  /// Failed agent execute (ExecuteErrorInfo); survives reload when set
  executeError  Json?
  /// model | system | commit — only meaningful when role is assistant
  assistantSource String?
  agentId       String?
  execution     AgentExecution?
  branch        Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId, createdAt])
}

model AgentExecution {
  id                   String    @id @default(cuid())
  messageId            String    @unique
  sandboxId            String
  executionId          String?   @unique
  status               String    @default("running")
  startedAt            DateTime  @default(now())
  completedAt          DateTime?
  latestSnapshot       Json?
  accumulatedEvents    Json?
  lastSnapshotPolledAt DateTime?
  snapshotVersion      Int       @default(0) // Monotonic counter for optimistic concurrency
  message              Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([sandboxId, status])
}

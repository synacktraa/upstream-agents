# =============================================================================
# Test Environment Configuration
# =============================================================================
# Copy this file to .env.test and fill in the values
#
# IMPORTANT: Use a SEPARATE test database, NOT your production database!
# The tests will reset the database before running.
# =============================================================================

# Test Database (REQUIRED)
# Create a separate Neon branch or use a local PostgreSQL instance
# The URL MUST contain 'test', 'localhost', or '127.0.0.1' as a safety check
DATABASE_URL="postgresql://user:password@host/testdb?sslmode=require"

# Daytona API Key (REQUIRED)
# Used to create sandboxes during tests
DAYTONA_API_KEY="your_daytona_api_key"

# NextAuth Configuration
NEXTAUTH_SECRET="test-secret-for-e2e-tests"
NEXTAUTH_URL="http://localhost:4000"

# GitHub OAuth (placeholders - not used in tests)
GITHUB_CLIENT_ID="placeholder"
GITHUB_CLIENT_SECRET="placeholder"

# Enable test auth route (REQUIRED for tests)
ENABLE_TEST_AUTH="true"
